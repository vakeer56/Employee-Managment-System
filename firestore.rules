rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasValidDefaultLeaveBalances(data) {
      return !data.keys().hasAny(['defaultLeaveBalances'])
        || (
          data.defaultLeaveBalances is map
          && data.defaultLeaveBalances.keys().hasOnly([
            'casualLeave',
            'sickLeave',
            'earnedLeave',
            'wfh'
          ])
          && data.defaultLeaveBalances.casualLeave is number
          && data.defaultLeaveBalances.sickLeave is number
          && data.defaultLeaveBalances.earnedLeave is number
          && data.defaultLeaveBalances.wfh is number
          && data.defaultLeaveBalances.casualLeave >= 0
          && data.defaultLeaveBalances.sickLeave >= 0
          && data.defaultLeaveBalances.earnedLeave >= 0
          && data.defaultLeaveBalances.wfh >= 0
        );
    }

    function hasValidOrgSettings(data) {
      return data.keys().hasOnly([
          'departments',
          'designations',
          'defaultLeaveBalances'
        ])
        && data.departments is list
        && data.designations is list
        && hasValidDefaultLeaveBalances(data);
    }

    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read, write: if request.auth != null;
    }

    match /settings/org {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && hasValidOrgSettings(request.resource.data);
      allow delete: if false;
    }

    // --- NEW RULES FOR LEAVE MANAGEMENT ---
    match /leaves/{leaveId} {
      allow read, write: if request.auth != null;
    }

    match /leaveBalances/{balanceId} {
      allow read, write: if request.auth != null;
    }
    // --------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
